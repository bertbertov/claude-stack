# coturn config for the WebRTC camera/mic call. Relays only when a direct peer-to-peer
# path is blocked (CGNAT / restrictive mobile+home ISPs across countries). Tiny bandwidth:
# a 360p call is ~0.4 Mbit/s each way.
#
# Set your OWN values. Put the same host/user/password into player.html's {{TURN_*}}.
# Generate a password: openssl rand -hex 10
# Open firewall: ufw allow 3478 ; ufw allow 49160:49200/udp
# Verify it relays: turnutils_uclient -y -u cinema -w YOUR_PASSWORD -n 4 YOUR_SERVER_IP
#   -> expect "Total lost packets 0"

listening-port=3478
fingerprint
lt-cred-mech
user=cinema:CHANGE_ME_RANDOM_PASSWORD
realm=cinema.example.com
external-ip=YOUR_SERVER_PUBLIC_IP
min-port=49160
max-port=49200
no-tcp-relay
no-cli
stale-nonce=600
simple-log
log-file=/var/log/turnserver.log
